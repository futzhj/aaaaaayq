# Gradle build outputs
.gradle/
build/

# Local environment (machine-specific)
local.properties

# Precompiled native libs (generated by build_android.ps1)
# 忽略内容但允许 SDL 预编译 .so (CI 链接需要 DT_NEEDED)
app/src/main/jniLibs/*
!app/src/main/jniLibs/*/
app/src/main/jniLibs/*/*
!app/src/main/jniLibs/*/libSDL2.so
!app/src/main/jniLibs/*/libSDL_image.so
!app/src/main/jniLibs/*/libSDL_mixer.so
!app/src/main/jniLibs/*/libSDL_ttf.so
