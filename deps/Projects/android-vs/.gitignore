# ── MSBuild 平台编译缓存 ──
.ARM/
.ARM64/
.x86/
.x64/

# ── 编译产物 ──
build_output/
output/
*.so
!**/libSDL2.so
!**/libSDL_image.so
!**/libSDL_mixer.so
!**/libSDL_ttf.so
*.a
*.recipe

# ── Gradle 缓存 ──
app/GGELUA/.gradle/
app/GGELUA/build/
app/GGELUA/app/build/

# ── jniLibs: 忽略编译产物但保留 SDL 预编译 .so (CI DT_NEEDED) ──
app/GGELUA/app/src/main/jniLibs/*
!app/GGELUA/app/src/main/jniLibs/*/
app/GGELUA/app/src/main/jniLibs/*/*
!app/GGELUA/app/src/main/jniLibs/*/libSDL2.so
!app/GGELUA/app/src/main/jniLibs/*/libSDL_image.so
!app/GGELUA/app/src/main/jniLibs/*/libSDL_mixer.so
!app/GGELUA/app/src/main/jniLibs/*/libSDL_ttf.so

# ── 子项目 MSBuild 中间产物 ──
app/GGELUA/.ARM*/
app/GGELUA/.x*/

# ── IDE / OS ──
.vs/
*.user
Thumbs.db
.DS_Store
